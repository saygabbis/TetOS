# Modo do cérebro: local (Ollama na máquina) ou cloud (API em ollama.com)
TETOS_OLLAMA_MODE=local

# Local: URL do daemon Ollama (ignorado quando TETOS_OLLAMA_MODE=cloud)
TETOS_OLLAMA_URL=http://localhost:11434

# Cloud: chave em https://ollama.com/settings/keys (obrigatória se TETOS_OLLAMA_MODE=cloud)
# Também aceita OLLAMA_API_KEY (convenção oficial da Ollama).
# TETOS_OLLAMA_API_KEY=

# Cloud: host da API (padrão https://ollama.com)
# TETOS_OLLAMA_CLOUD_URL=https://ollama.com

# Modelo: no modo local o padrão é llama3; no cloud o padrão é minimax-m2.7:cloud
TETOS_MODEL=llama3
# Criatividade do modelo (0–2). Padrão 0.65 — um pouco mais preso ao que foi pedido; suba se quiser mais solto.
# TETOS_OLLAMA_TEMPERATURE=0.65
# Máximo de tokens gerados por resposta (Ollama). Padrão 400 — costuma deixar o chat mais rápido; 0 ou unlimited = sem limite.
# TETOS_OLLAMA_NUM_PREDICT=400
TETOS_MEMORY_PATH=./data/memory.json
TETOS_MAX_SHORT=8
TETOS_PORT=3000
TETOS_PERSONALITY_PATH=./data/personality.json
TETOS_MAX_HISTORY=12
TETOS_MAX_CONTENT=2000
TETOS_MAX_ID=64
TETOS_MAX_TAGS=10
TETOS_RESPONSE_HISTORY=5
TETOS_RESPONSE_SIMILARITY=0.75
# Opcional: teto de bolhas por resposta. Omita (padrão) = sem limite artificial.
# TETOS_RESPONSE_MAX_PARTS=8
WHATSAPP_ENABLED=true
WHATSAPP_SESSION_PATH=./data/session
WHATSAPP_AUTO_CONNECT=true
PRESENCE_ENABLED=true
PRESENCE_CHECK_MS=60000
PRESENCE_MIN_COOLDOWN_MS=1800000
PRESENCE_MAX_COOLDOWN_MS=7200000
PRESENCE_MAX_DAILY_PER_USER=3
PRESENCE_INACTIVE_MS=600000
